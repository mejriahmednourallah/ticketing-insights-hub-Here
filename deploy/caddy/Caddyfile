{
	auto_https off
	admin off
}

:8080 {
	encode zstd gzip

	@chatRequest path /functions/v1/chat
	request_body @chatRequest {
		max_size 256KB
	}

	header {
		-Server
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	route {
		handle /healthz {
			respond "ok" 200
		}

		handle_path /api/analytics/* {
			reverse_proxy analytics-api:8000
		}

		# Rate-limited chat endpoint (10 requests/min per client)
		handle /functions/v1/chat {
			rate_limit {
				zone chat {
					key {remote_host}
					events 10
					window 1m
				}
			}
			reverse_proxy kong:8000
		}

		# Other functions (redmine-ingest called internally by scheduler)
		handle /functions/v1/* {
			reverse_proxy kong:8000
		}

		handle /auth/v1/* {
			reverse_proxy kong:8000
		}

		handle /rest/v1/* {
			reverse_proxy kong:8000
		}

		handle_path /admin/studio* {
			basic_auth {
				admin {$ADMIN_PASSWORD_HASH}
			}
			reverse_proxy studio:3000
		}

		@studioAssets path /_next/* /api/platform/* /api/profile* /api/projects* /project/* /organization/* /settings/* /account/*
		handle @studioAssets {
			basic_auth {
				admin {$ADMIN_PASSWORD_HASH}
			}
			reverse_proxy studio:3000
		}

		handle /admin/grafana* {
			basic_auth {
				admin {$ADMIN_PASSWORD_HASH}
			}
			reverse_proxy grafana:3000 {
				header_up -Authorization
			}
		}

		handle {
			header Content-Security-Policy "default-src 'self'; connect-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-ancestors 'none'"
			reverse_proxy web:80
		}
	}
}
