# Redmine source
REDMINE_URL=https://maintenance.medianet.tn
REDMINE_API_KEY=replace_me
REDMINE_PAGE_SIZE=500
REDMINE_PROJECT_BATCH_SIZE=20

# Supabase destination
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Frontend Supabase client
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace_me
VITE_ANALYTICS_API_URL=http://127.0.0.1:8000

# DuckDB analytics API / refresh worker
SUPABASE_JWT_SECRET=replace_me
ANALYTICS_AUTH_DISABLED=false
WAREHOUSE_REFRESH_SECONDS=300
DBT_SUPABASE_HOST=host.docker.internal
DBT_SUPABASE_PORT=54322
DBT_SUPABASE_USER=postgres
DBT_SUPABASE_PASSWORD=postgres
DBT_SUPABASE_DBNAME=postgres

# Optional Prometheus/Grafana monitoring profile
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_a_strong_password
PROMETHEUS_RETENTION=15d

# Local Supabase edge function trigger (for local stack)
SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321

# AI chat assistant
LOVABLE_API_KEY=replace_me

# Optional Redmine custom-field aliases used by the ingestion function
REDMINE_FIELD_TEAM="Equipe Affectee,team"
REDMINE_FIELD_TECHNOLOGY="CMS / Framework,technology,technology_used"
REDMINE_FIELD_NATURE="Nature,nature"
REDMINE_FIELD_INTERVENTION_TYPE="Type d'intervention,intervention_type"
REDMINE_FIELD_RESOLVED_DATE="Date Resolved,resolved_date"
REDMINE_FIELD_SATISFACTION="Degre de satisfaction,Degre de satisfaction,csat_score,satisfaction"
REDMINE_FIELD_SOURCE=Source,source
REDMINE_FIELD_CANAL=Canal,channel,canal
REDMINE_FIELD_SEGMENT_CLIENT="Segment client,customer_segment,segment_client"
REDMINE_FIELD_REGION="Region,region"
REDMINE_FIELD_REOPENED="Reouvert,reouvert,reopened"
REDMINE_FIELD_SLA_PLAN="SLA plan,sla_plan"
