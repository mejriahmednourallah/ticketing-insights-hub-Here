FROM python:3.12-slim

WORKDIR /app

COPY analytics_service/requirements-worker.txt /app/requirements-worker.txt
RUN pip install --no-cache-dir -r /app/requirements-worker.txt

COPY ticketing_warehouse /app/ticketing_warehouse
COPY analytics_service /app/analytics_service

ENV PYTHONPATH=/app
CMD ["python", "-m", "analytics_service.refresh_worker"]
